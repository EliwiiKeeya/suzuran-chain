# ============================================================
# LLM 配置
# ============================================================

# API 密钥 - 用于认证 AI 服务
# 从你的 AI 服务提供商获取（如 OpenAI、DeepSeek 等）
OPENAI_API_KEY=your_api_key_here

# API 基础地址 - AI 服务的访问地址
# 示例: https://api.openai.com/v1
#       https://api.modelarts-maas.com/openai/v1
OPENAI_BASE_URL=https://api.example.com/v1

# 模型名称 - 指定使用的 AI 模型
# 示例: gpt-4o-mini, deepseek-v4-flash, qwen2-7b-instruct
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# 可选配置
# ============================================================

# 访问令牌 - 用于客户端与后端之间的认证（可选）
ACCESS_TOKEN=test-token

# 后端服务地址 - 服务绑定的主机地址
BACKEND_HOST=0.0.0.0

# 后端服务端口 - 服务监听的端口号
BACKEND_PORT=8000

# 温度参数 - 控制输出的随机性
# 值越大越随机（0.0-2.0），默认 0.7
TEMPERATURE=0.7

# 最大令牌数 - 控制单次响应的最大长度
# 默认 2048，根据模型能力调整
MAX_TOKENS=2048
